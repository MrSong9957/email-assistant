# ── Account list ──────────────────────────────────
# 账户列表（逗号分隔）
MAIL_ACCOUNTS=qq,gmail

# ── QQ Mail ───────────────────────────────────────
# QQ 邮箱凭证
QQ_MAIL_USER=your@qq.com
QQ_MAIL_APP_PASSWORD=your_qq_app_password

# ── Gmail ─────────────────────────────────────────
# Gmail 凭证
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ── SOCKS5 Proxy ──────────────────────────────────
# 境外邮箱代理（Gmail、Outlook 等），国内用户需要配置
# 国外用户无需配置，直接直连
# 根据你的系统，取消对应两行的注释即可（删掉行首的 #）
#
# [本机] Windows / Linux / macOS（代理运行在本机）：
# SOCKS5_PROXY_HOST=127.0.0.1
# SOCKS5_PROXY_PORT=7890
#
# [Docker] 运行在容器内（代理运行在宿主机）：
# SOCKS5_PROXY_HOST=host.docker.internal
# SOCKS5_PROXY_PORT=7890
#
# [WSL2] 代理运行在 Windows 宿主机：
# SOCKS5_PROXY_HOST=host.docker.internal
# SOCKS5_PROXY_PORT=7890

# ── Advanced ──────────────────────────────────────
# 以下各项均有内置默认值，通常无需修改
# QQ_MAIL_IMAP_HOST=imap.qq.com
# QQ_MAIL_IMAP_PORT=993
# QQ_MAIL_SMTP_HOST=smtp.qq.com
# QQ_MAIL_SMTP_PORT=465
# QQ_MAIL_ARCHIVE_FOLDER=Archives
# QQ_MAIL_SENT_FOLDER=Sent Messages
# GMAIL_IMAP_HOST=imap.gmail.com
# GMAIL_IMAP_PORT=993
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=465
# GMAIL_ARCHIVE_FOLDER=[Gmail]/All Mail
# GMAIL_SENT_FOLDER=[Gmail]/Sent Mail
